# Environment Variables Example for Not Just Cuts Website

# Base Site URL
NEXT_PUBLIC_SITE_URL=https://notjustcuts.example.com

# Form Handling API Keys (e.g. Resend, Formspree, EmailJS)
# RESEND_API_KEY=re_123456789
# BUSINESS_NOTIFICATION_EMAIL=info@notjustcutssalon.example.com

# Optional SMS Integration (Twilio / MessageBird placeholder)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Optional Google Analytics 4 Measurement ID
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
